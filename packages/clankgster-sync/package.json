{
  "name": "@clankgster/sync",
  "version": "0.1.0-alpha.2",
  "description": "Node tooling and TypeScript scripts for Clankgster sync workflows (publishable).",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/flycrum/clankgster.git",
    "directory": "packages/clankgster-sync"
  },
  "bin": {
    "clankgster-sync": "./bin/clankgster-sync.mjs"
  },
  "files": [
    "bin",
    "CHANGELOG.md",
    "dist",
    "scripts",
    "src"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./scripts/clankgster-sync.clear": "./dist/scripts/clankgster-sync.clear.mjs",
    "./scripts/clankgster-sync.run": "./dist/scripts/clankgster-sync.run.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack index.ts scripts/clankgster-sync.run.ts scripts/clankgster-sync.clear.ts",
    "check": "vp check index.ts src scripts exports bin vite.config.ts",
    "clankgster-sync:clear": "CLANKGSTER_SYNC_EXECUTION_MODE=source node ./bin/clankgster-sync.mjs clear",
    "clankgster-sync:run": "CLANKGSTER_SYNC_EXECUTION_MODE=source node ./bin/clankgster-sync.mjs run",
    "dev": "vp pack index.ts scripts/clankgster-sync.run.ts scripts/clankgster-sync.clear.ts --watch",
    "pack-local:tarball": "bash internal/scripts/local-tarball-pack.sh",
    "prepack": "pnpm run build",
    "prepublishOnly": "pnpm run build",
    "release:preflight": "bash internal/scripts/npm-release-preflight.sh",
    "release:publish:alpha": "bash internal/scripts/npm-release-publish-from-pack.sh alpha",
    "test": "vp test"
  },
  "dependencies": {
    "@types/lodash-es": "catalog:",
    "chalk": "catalog:",
    "lodash-es": "catalog:",
    "mdast-util-to-string": "catalog:",
    "neverthrow": "catalog:",
    "pino": "catalog:",
    "remark-frontmatter": "catalog:",
    "remark-parse": "catalog:",
    "remark-stringify": "catalog:",
    "unified": "catalog:",
    "unist-util-visit": "catalog:",
    "xstate": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@clankgster/typescript-config": "workspace:*",
    "@clankgster/vite-plus-config": "workspace:*",
    "@types/mdast": "catalog:",
    "@types/node": "catalog:",
    "@typescript/native-preview": "7.0.0-dev.20260316.1",
    "oxlint": "catalog:",
    "tsx": "^4.19.0",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "inlinedDependencies": {
    "@types/mdast": "4.0.4",
    "@types/unist": "3.0.3"
  }
}
