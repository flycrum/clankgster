{
  "claude": {
    "markdownContextSymlink": {
      "options": {
        "sourceFile": "CLANK.md",
        "targetFile": "CLAUDE.md",
        "gitignoreComment": "\n# __CLANKGSTERS_LOCAL_MARKETPLACE_NAME__: symlinked from AGENTS.md for Claude\n",
        "gitignoreEntry": "CLAUDE.md"
      },
      "symlinks": ["CLAUDE.md", "packages/app/CLAUDE.md"]
    },
    "localMarketplaceSync": {
      "options": {
        "manifestKey": "claude",
        "marketplaceFile": ".claude-plugin/marketplace.json",
        "marketplaceName": "__CLANKGSTERS_LOCAL_MARKETPLACE_NAME__",
        "sourceFormat": "prefixed"
      },
      "customData": {
        "plugins": [
          {
            "name": "nested",
            "source": "./packages/app/.clank/plugins/nested",
            "description": "Fake nested plugin under packages/app for e2e test sandbox.",
            "version": "0.1.0"
          }
        ]
      }
    },
    "rulesSymlink": {
      "options": {
        "rulesDir": ".claude/rules",
        "syncManifest": ".claude/.clankgsters-claude-sync.json"
      },
      "symlinks": []
    },
    "skillsDirectorySync": {
      "options": {},
      "symlinks": [".claude/skills/sample-skill"]
    },
    "settingsSync": {
      "options": {
        "manifestKey": "claude",
        "marketplaceName": "__CLANKGSTERS_LOCAL_MARKETPLACE_NAME__",
        "settingsFile": ".claude/settings.json"
      }
    }
  },
  "cursor": {
    "skillsDirectorySync": {
      "options": {},
      "symlinks": []
    },
    "localPluginsContentSync": {
      "options": {
        "customHandler": {},
        "requiredManifestKey": "cursor",
        "targetRoot": ".cursor"
      },
      "symlinks": [".cursor/commands/nested/nested-cmd.md"],
      "fsAutoRemoval": []
    }
  },
  "codex": {
    "markdownContextSymlink": {
      "options": {
        "sourceFile": "CLANK.md",
        "targetFile": "AGENTS.md",
        "gitignoreComment": "\n# __CLANKGSTERS_LOCAL_MARKETPLACE_NAME__: symlinked from CLANK.md for Codex\n",
        "gitignoreEntry": "AGENTS.md"
      },
      "symlinks": ["AGENTS.md", "packages/app/AGENTS.md"]
    },
    "skillsDirectorySync": {
      "options": {},
      "symlinks": []
    },
    "markdownSectionSync": {
      "options": {
        "agentsFile": "AGENTS.override.md",
        "sectionHeading": "packages (generated by clankgsters)"
      }
    }
  },
  "testagent": {
    "skillsDirectorySync": {
      "options": {},
      "symlinks": []
    },
    "markdownSectionSync": {
      "options": {
        "agentsFile": "AGENTS.override.md",
        "sectionHeading": "packages (generated by clankgsters)"
      }
    }
  }
}
